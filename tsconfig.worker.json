{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx"
  },
  "include": ["src/lib/**/*.ts", "src/server/**/*.ts", "src/types/**/*.ts", "src/workers/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "src/app"]
}
